    -- RenderStepped (now handles backgrounds + improved cheats)
    RunService.RenderStepped:Connect(function(dt)
        local t = tick()
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
            -- movement (fly, noclip, ws) unchanged
            local hum = char.Humanoid
            local hrp = char.HumanoidRootPart
            hum.WalkSpeed = Settings.WS
            -- fly/noclip code unchanged...
        end

        -- === BACKGROUND ANIMATION (all effects) ===
        if Settings.BackgroundEffect == "Classic Particles" then
            if math.random(1,12) == 1 and #Particles < 30 then
                BackgroundObjects.SpawnFunc()
            end
            for i = #Particles, 1, -1 do
                local data = Particles[i]
                if data.Object then
                    data.Object.Position = UDim2.new(data.Object.Position.X.Scale + math.sin(t + data.Phase)*0.0008, 0,
                        data.Object.Position.Y.Scale - data.Speed * dt * 12, 0)
                    if data.Object.Position.Y.Scale < -0.1 then
                        data.Object:Destroy()
                        table.remove(Particles, i)
                    end
                end
            end

        elseif Settings.BackgroundEffect == "Snowing" then
            for _, data in pairs(BackgroundObjects) do
                data.Obj.Position = UDim2.new(data.Obj.Position.X.Scale + data.Drift, 0,
                    data.Obj.Position.Y.Scale + data.Speed * dt * 18, 0)
                data.Obj.Rotation = data.Obj.Rotation + data.RotSpeed
                if data.Obj.Position.Y.Scale > 1.1 then
                    data.Obj.Position = UDim2.new(math.random(), 0, -0.2, 0)
                end
            end

        elseif Settings.BackgroundEffect == "Ethereal Smoke" then
            for _, data in pairs(BackgroundObjects) do
                data.Obj.Position = UDim2.new(data.Obj.Position.X.Scale + data.Dir * data.Speed * dt * 8, 0,
                    data.Obj.Position.Y.Scale - data.Speed * dt * 3, 0)
                if data.Obj.Position.X.Scale < -0.4 or data.Obj.Position.X.Scale > 1.4 then
                    data.Dir = -data.Dir
                end
            end

        elseif Settings.BackgroundEffect == "Thunder Storm" then
            -- occasional lightning
            if tick() - BackgroundObjects[1].LastFlash > math.random(0.8,3) then
                BackgroundObjects[1].LastFlash = tick()
                local bolt = Instance.new("Frame", BackgroundContainer)
                bolt.Size = UDim2.new(0, 3, 0, math.random(180,320))
                bolt.Position = UDim2.new(math.random(), 0, -0.1, 0)
                bolt.BackgroundColor3 = Color3.fromRGB(255,255,255)
                bolt.ZIndex = 5
                TweenService:Create(bolt, TweenInfo.new(0.12), {BackgroundTransparency = 1}):Play()
                game.Debris:AddItem(bolt, 0.3)
            end

        elseif Settings.BackgroundEffect == "Neon Matrix Rain" then
            for _, data in pairs(BackgroundObjects) do
                data.Obj.Position = UDim2.new(data.Obj.Position.X.Scale, 0,
                    data.Obj.Position.Y.Scale + data.Speed * dt * 22, 0)
                if data.Obj.Position.Y.Scale > 1.2 then
                    data.Obj.Position = UDim2.new(math.random(), 0, -0.3, 0)
                    data.Obj.Text = math.random() > 0.5 and "01" or "10"
                end
            end

        elseif Settings.BackgroundEffect == "Fire Embers" then
            for _, data in pairs(BackgroundObjects) do
                data.Obj.Position = UDim2.new(data.Obj.Position.X.Scale + data.XDrift, 0,
                    data.Obj.Position.Y.Scale - data.Speed * dt * 15, 0)
                data.Obj.BackgroundTransparency = data.Obj.BackgroundTransparency + 0.008
                if data.Obj.BackgroundTransparency > 0.95 then
                    data.Obj.Position = UDim2.new(math.random(), 0, 1, 0)
                    data.Obj.BackgroundTransparency = 0
                end
            end

        elseif Settings.BackgroundEffect == "Cosmic Orbs" then
            for _, data in pairs(BackgroundObjects) do
                local x = 0.5 + math.sin(t * data.Speed + data.Phase) * 0.42
                local y = 0.5 + math.cos(t * data.Speed * 0.7 + data.Phase) * 0.38
                data.Obj.Position = UDim2.new(x, 0, y, 0)
                data.Obj.Rotation = data.Obj.Rotation + 0.8
            end
        end

        -- === IMPROVED AIMBOT (humanized) ===
        if Settings.Aimbot then
            local target, sDist = nil, Settings.FOV
            -- (target finding loop unchanged)

            if target then
                totalLocks = totalLocks + 1
                if Settings.TargetPart == "Head" then headLocks = headLocks + 1 end
                local rate = math.floor((headLocks / totalLocks) * 100 + 0.5)
                HeadshotLabel.Text = "Headshot Rate: " .. rate .. "%"

                -- Humanized smoothing + micro jitter
                local jitter = Vector3.new(math.sin(t*25)*0.4, math.cos(t*18)*0.3, 0)
                local finalTarget = target.Position + jitter * 0.035
                local lerpAlpha = math.clamp(Settings.Smoothing + math.random(-4,4)/100, 0.15, 0.95)
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, finalTarget), lerpAlpha)
            end
        else
            totalLocks = 0
            headLocks = 0
            HeadshotLabel.Text = "Headshot Rate: 0%"
        end

        -- === IMPROVED SILENT AIM (better prediction) ===
        if Settings.SilentAim then
            local closest, dist = nil, Settings.FOV
            -- (finding loop unchanged)

            if closest then
                local aimPos = closest.Position + closest.Velocity * ( (closest.Position - Camera.CFrame.Position).Magnitude / 650 )
                aimPos = aimPos + Vector3.new(math.random(-3,3), math.random(-2,4), 0) * 0.03 -- micro human offset
                Mouse.Hit = CFrame.new(Camera.CFrame.Position, aimPos)
            end
        end

        -- === IMPROVED TRIGGERBOT (stealthiest method) ===
        if Settings.Triggerbot and Mouse.Target then
            local target = Mouse.Target
            if target and target.Parent and target.Parent:FindFirstChild("Humanoid") then
                local hum = target.Parent.Humanoid
                if hum.Health > 0 then
                    local player = Players:GetPlayerFromCharacter(target.Parent)
                    if player and player ~= LocalPlayer and (not Settings.TeamCheck or player.Team ~= LocalPlayer.Team) then
                        local delay = Settings.TriggerDelay + math.random(-22, 38) / 1000
                        task.wait(delay)

                        VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, true, game, 1) -- down
                        task.wait(math.random(1,6)/100) -- human hold time
                        VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, false, game, 1) -- up
                    end
                end
            end
        end

        -- === IMPROVED RECOIL (only when shooting + variation) ===
        if Settings.RecoilControl and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            local strength = Settings.RecoilStrength / 280
            local xVar = math.random(-8,8) / 100
            mousemoverel(xVar, strength + math.random(-4,7)/100)
        end

        -- FOV circle
        fovGui.Enabled = Settings.Aimbot and Settings.ShowFOVCircle
    end)

    -- (Rest of the script - tab buttons, kill/minimize, etc. unchanged)
end

