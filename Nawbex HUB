                flake.ImageColor3 = Settings.Accent
                flake.ImageTransparency = 0.2
                Instance.new("UICorner", flake).CornerRadius = UDim.new(1,0)
                table.insert(BackgroundObjects, {
                    Obj = flake,
                    Speed = math.random(25,70)/100,
                    Drift = math.random(-15,15)/1000,
                    RotSpeed = math.random(-3,3)/10
